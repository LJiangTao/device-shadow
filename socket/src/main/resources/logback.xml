<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <conversionRule conversionWord="processId" converterClass="com.lee.iot.socket.logging.ProcessIdConverter"/>

    <property name="CONSOLE_LOG_PATTERN"
              value="%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} %5level %processId --- [%15.15thread] %-40.40logger{39} : %msg%n%ex"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>
